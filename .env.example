# =============================================================================
# Autoprocs Dispatcher — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# Nunca commit `.env.local`. Veja .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (cliente + server)
# Pegue em: https://supabase.com/dashboard/project/<id>/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# -----------------------------------------------------------------------------
# Meta / WhatsApp Cloud API
# App ID/Secret: https://developers.facebook.com/apps/<app-id>/settings/basic/
# Embedded Signup Config ID: criado em WhatsApp > Embedded Signup
# -----------------------------------------------------------------------------
META_APP_ID="<meta-app-id>"
META_APP_SECRET="<meta-app-secret>"
META_EMBEDDED_SIGNUP_CONFIG_ID="<config-id>"
META_GRAPH_API_VERSION="v21.0"
META_VERIFY_TOKEN="<random-string-for-webhook-verification>"

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
